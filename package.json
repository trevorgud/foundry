{
  "name": "foundry",
  "version": "1.0.0",
  "description": "Minimal Docker Compose setup for running Foundry Virtual Tabletop with a manually supplied Node.js distribution zip.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:engine": "node --test tests/movement-engine.spec.js",
    "test:state:schema": "node --test tests/state-schema.spec.js",
    "test:state:schema:live": "sh -lc 'FOUNDRY_STATE_OUTPUT=test-results/pawn16-state-live-schema.json node scripts/foundry-state.mjs && node scripts/validate-state-schema.mjs test-results/pawn16-state-live-schema.json'",
    "test:foundry": "playwright test tests/foundry-smoke.spec.js",
    "test:foundry:health": "playwright test tests/foundry-smoke.spec.js --grep \"Pawn16 world is healthy\"",
    "test:foundry:rules": "playwright test tests/foundry-smoke.spec.js --grep \"Pawn16 piece rules\"",
    "foundry:state": "node scripts/foundry-state.mjs",
    "foundry:state:debug": "node scripts/foundry-state.mjs",
    "foundry:state:fixtures": "node scripts/generate-state-fixtures.mjs",
    "foundry:screenshot": "node scripts/foundry-screenshot.mjs",
    "foundry:configure-world": "node scripts/configure-foundry.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "ajv": "^8.20.0"
  }
}
